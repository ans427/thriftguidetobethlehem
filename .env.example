VITE_SANITY_PROJECT_ID=s0509l0r
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2025-01-01

# Browser requests: add your dev origin in Sanity Manage → API → CORS origins:
#   http://localhost:5173
#   http://127.0.0.1:5173
#
# If the dataset is not public, create an API token (Viewer) and paste it here:
# VITE_SANITY_API_READ_TOKEN=

# Optional: post visitor comments from the site.
# Create the token on THIS project: Manage → API → Tokens → Add API token → Editor (Viewer cannot create).
# If you see 401 "Session not found", the token is wrong/revoked or not a project token—create a new one.
# Browser mutations also need CORS: Manage → API → CORS origins → http://localhost:5173
# VITE_SANITY_API_WRITE_TOKEN=

# Optional: Sanity CLI / Studio (if you use a different project or dataset)
# SANITY_STUDIO_PROJECT_ID=s0509l0r
# SANITY_STUDIO_DATASET=production
