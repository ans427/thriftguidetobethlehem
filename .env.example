VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2025-01-01

# Browser requests: add your dev origin in Sanity Manage → API → CORS origins:
#   http://localhost:5173
#   http://127.0.0.1:5173
#
# If the dataset is not public, create an API token (Viewer) and paste it here:
# VITE_SANITY_API_READ_TOKEN=

# Local-only optional: post comments directly from browser (not recommended for production)
# VITE_SANITY_API_WRITE_TOKEN=

# Production preferred (server-side only, e.g. Vercel Project Settings -> Environment Variables):
# SANITY_PROJECT_ID=your_project_id
# SANITY_DATASET=production
# SANITY_API_VERSION=2025-01-01
# SANITY_WRITE_TOKEN=sk...

# Optional: Sanity CLI / Studio (if you use a different project or dataset)
# SANITY_STUDIO_PROJECT_ID=your_project_id
# SANITY_STUDIO_DATASET=production
